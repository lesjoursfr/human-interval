{
	"name": "@lesjoursfr/human-interval",
	"version": "3.0.1",
	"description": "Human readable time measurements",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lesjoursfr/human-interval.git"
	},
	"homepage": "https://github.com/lesjoursfr/human-interval#readme",
	"bugs": {
		"url": "https://github.com/lesjoursfr/human-interval/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": "22.x || 24.x || 26.x"
	},
	"keywords": [
		"interval",
		"time",
		"date"
	],
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"type": "module",
	"scripts": {
		"freshlock": "rm -rf node_modules/ && rm .yarn/install-state.gz && rm yarn.lock && yarn",
		"check-lint": "eslint",
		"check-format": "prettier --check .",
		"check-tsc": "tsc --noEmit",
		"lint": "eslint --fix",
		"format": "prettier --write .",
		"build": "tsc -p tsconfig.build.json",
		"test": "NODE_OPTIONS='--loader=ts-node/esm' mocha"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@tsconfig/node22": "22.0.5",
		"@types/mocha": "10.0.10",
		"@types/node": "24.13.2",
		"eslint": "10.5.0",
		"eslint-config-prettier": "10.1.8",
		"globals": "17.7.0",
		"mocha": "11.7.6",
		"prettier": "3.8.4",
		"ts-node": "10.9.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.62.0"
	},
	"packageManager": "yarn@4.17.0"
}
